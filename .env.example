# メール配信設定
# このファイルを .env にコピーして各値を設定してください
# .env はGitにコミットしないでください（.gitignoreに追加済み）

# 配信先メールアドレス（必須）
RECIPIENT_EMAIL=your-address@example.com

# SendGrid APIキー（必須）
# 取得方法: sendgrid.com → Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# 差出人メールアドレス（SendGridで送信者認証済みのアドレス）
SENDER_EMAIL=your-verified-email@example.com

# 設定ファイルパス（省略時: config.yaml）
# CONFIG_PATH=config.yaml

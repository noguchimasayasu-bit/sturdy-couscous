# メール配信設定
# このファイルを .env にコピーして各値を設定してください
# .env はGitにコミットしないでください（.gitignoreに追加済み）

# 配信先メールアドレス（必須）
RECIPIENT_EMAIL=your-address@example.com

# 送信元 Gmail アドレス（必須）
SMTP_USER=your-gmail@gmail.com

# Gmail アプリパスワード（必須）
# 取得方法: Googleアカウント → セキュリティ → 2段階認証 → アプリパスワード
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 以下はデフォルト値（変更不要な場合は省略可）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-gmail@gmail.com

# 設定ファイルパス（省略時: config.yaml）
# CONFIG_PATH=config.yaml

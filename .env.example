# メール配信設定
# このファイルを .env にコピーして各値を設定してください
# .env はGitにコミットしないでください（.gitignoreに追加済み）

# 配信先メールアドレス（必須）
RECIPIENT_EMAIL=your-address@example.com

# 送信元 Gmail アドレス（必須）
SMTP_USER=your-gmail@gmail.com

# Gmail アプリパスワード 16文字（スペースなし）（必須）
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# 以下はデフォルト値（変更不要）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-gmail@gmail.com
